# ============================================================================
# Vercel frontend env (Production). Paste these into Vercel -> Project ->
# Settings -> Environment Variables. Replace the two <...> placeholders with
# your real Render backend URL and your Vercel domain. DO NOT commit real
# secrets — .env.local is git-ignored; this is a template.
# ============================================================================

# ── Backend (Render all-in-one gateway) ────────────────────────────────────
# Replace with the URL Render gives you, e.g. https://gtproject-backend.onrender.com
NEXT_PUBLIC_GLIMMORA_API_URL=https://<your-render-backend>.onrender.com
GLIMMORA_API_URL=https://<your-render-backend>.onrender.com
API_BASE_URL=https://<your-render-backend>.onrender.com
NEXT_PUBLIC_API_BASE_URL=https://<your-render-backend>.onrender.com
BACKEND_SERVICE_URL=https://<your-render-backend>.onrender.com
INTERNAL_BACKEND_URL=https://<your-render-backend>.onrender.com

# ── NextAuth ────────────────────────────────────────────────────────────────
# MUST equal the backend API_SECRET_KEY so JWTs interoperate across both apps.
# Use the SAME value you set for the backend API_SECRET_KEY (your local .env.local
# AUTH_SECRET). Generate a fresh one for prod with: openssl rand -hex 32
AUTH_SECRET=<same-value-as-backend-API_SECRET_KEY>
# Replace with your real Vercel production domain (no trailing slash).
NEXTAUTH_URL=https://<your-app>.vercel.app
NEXT_PUBLIC_BASE_URL=https://<your-app>.vercel.app

# ── Frontend's own Prisma DB (NextAuth credentials store) — Neon ────────────
# Use the SAME glimmora_fe4 URL that's in your local .env.local.
DATABASE_URL=postgresql://<user>:<pass>@<host>.neon.tech/glimmora_fe4?sslmode=require

# ── Glimmora admin (super admin) — used by admin proxy routes ───────────────
GLIMMORA_ADMIN_EMAIL=superadmin@glimmora.dev
GLIMMORA_ADMIN_PASSWORD=glimmora123

# ── Service accounts (SOW / decomposition proxy routes) ─────────────────────
GLIMMORA_SERVICE_EMAIL=sow-test-user@glimmora.com
GLIMMORA_SERVICE_PASSWORD=Test@12345
GLIMMORA_ENTERPRISE_SERVICE_EMAIL=enterprise-service@glimmora.com
GLIMMORA_ENTERPRISE_SERVICE_PASSWORD=Test@12345

# ── Email (SMTP / Gmail) — frontend's direct email routes ───────────────────
# Copy the real values from your local .env.local.
SMTP_USER=<your gmail>
SMTP_PASSWORD=<gmail app password>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_FROM=<your gmail>

# ── OAuth (contributors only) — copy real values from .env.local ────────────
GOOGLE_CLIENT_ID=<google client id>
GOOGLE_CLIENT_SECRET=<google client secret>
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# ── Demo flags ──────────────────────────────────────────────────────────────
# Remove NEXT_PUBLIC_MENTOR_DEMO for a true production gate; keep for demo.
NEXT_PUBLIC_MENTOR_DEMO=1
