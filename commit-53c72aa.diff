new file mode 100644
index 0000000..83c6942
--- /dev/null
+++ b/src/types/next-auth.d.ts
@@ -0,0 +1,26 @@
+import type { UserRole } from "@/auth";
+
+declare module "next-auth" {
+  interface User {
+    role?: UserRole;
+    initials?: string;
+  }
+
+  interface Session {
+    user: {
+      id: string;
+      email: string;
+      name: string;
+      role: UserRole;
+      initials: string;
+      image?: string | null;
+    };
+  }
+}
+
+declare module "next-auth/jwt" {
+  interface JWT {
+    role?: UserRole;
+    initials?: string;
+  }
+}
