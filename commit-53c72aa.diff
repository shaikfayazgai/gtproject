+                    ? "text-brown-600 bg-brown-50"
+                    : "text-gray-400 hover:text-gray-600 hover:bg-gray-50"
+                )}
+              >
+                {cat.category}
+                {selectedCount > 0 && (
+                  <span
+                    className={cn(
+                      "ml-1.5 inline-flex items-center justify-center w-4 h-4 rounded-full text-[9px] font-bold",
