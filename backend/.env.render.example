# ============================================================================
# Render backend env — single all-in-one Web Service (Dockerfile.allinone).
# Copy each line into the Render service's Environment tab. These names match
# shared/config.py exactly (pydantic-settings, case-insensitive). DO NOT commit
# real secrets — backend/.env is git-ignored; this is only a template.
# ============================================================================

# Neon Postgres (the backend "glimmora" DB — same one you use locally).
DATABASE_URL=postgresql://<user>:<pass>@<host>.neon.tech/glimmora?sslmode=require

# JWT signing key — MUST equal the frontend's AUTH_SECRET so tokens interoperate.
# Use your local .env.local AUTH_SECRET, or generate: openssl rand -hex 32
API_SECRET_KEY=<same-value-as-frontend-AUTH_SECRET>

# Super admin seed (must match frontend GLIMMORA_ADMIN_* so admin proxy logs in).
SUPER_ADMIN_EMAIL=superadmin@glimmora.dev
SUPER_ADMIN_PASSWORD=glimmora123

# Email (Gmail SMTP) — names match shared/config.py (EMAIL_USER / EMAIL_APP_PASSWORD).
EMAIL_USER=<your gmail address>
EMAIL_APP_PASSWORD=<gmail app password (spaces ok)>
EMAIL_FROM=<your gmail address>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Stagger service starts so 9 schema-inits don't deadlock on the shared DB.
SERVICE_START_STAGGER=3

# NOTE: PORT is injected by Render automatically — do NOT set it.
